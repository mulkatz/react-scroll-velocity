{
	"name": "react-scroll-velocity",
	"version": "0.8.0",
	"description": "React hook & components for scroll-speed-based animations. Velocity text skew, speed-reactive marquee, parallax. Zero dependencies.",
	"type": "module",
	"license": "MIT",
	"author": "Franz Benthin",
	"repository": {
		"type": "git",
		"url": "https://github.com/mulkatz/react-scroll-velocity"
	},
	"homepage": "https://github.com/mulkatz/react-scroll-velocity#readme",
	"bugs": {
		"url": "https://github.com/mulkatz/react-scroll-velocity/issues"
	},
	"keywords": [
		"react-scroll-velocity",
		"scroll-velocity",
		"scroll-speed",
		"scroll-animation",
		"scroll",
		"velocity",
		"animation",
		"skew",
		"marquee",
		"react",
		"react-hook",
		"react-component"
	],
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"sideEffects": false,
	"engines": {
		"node": ">=18"
	},
	"files": ["dist"],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"prepublishOnly": "npm run build"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/react": "^19.2.14",
		"jsdom": "^28.1.0",
		"tsup": "^8.3.0",
		"typescript": "^5.7.0",
		"vitest": "^3.0.0"
	},
	"peerDependencies": {
		"react": ">=19.0.0"
	}
}
